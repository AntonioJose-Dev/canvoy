{%- assign cv = product.selected_or_first_available_variant -%}
{%- if cv.compare_at_price > cv.price -%}
  {%- assign savings_amount = cv.compare_at_price | minus: cv.price -%}
  {%- assign savings_pct = savings_amount | times: 100 | divided_by: cv.compare_at_price -%}
{%- endif -%}
{%- assign bullet_blocks = section.blocks | where: 'type', 'bullet' -%}

<style>
/* ── FASE 1: fondo explícito para que el texto siempre sea legible ── */
.mp { font-family: inherit; color: #111827; background: #fff; }
.mp .wrap { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

/* TRUST BAR */
.mp-trust {
  background: #111827 !important;
  color: #f9fafb !important;
  overflow: hidden;
  position: relative;
}
.mp-trust__track {
  display: flex;
  gap: 0;
  animation: mp-scroll 22s linear infinite;
  width: max-content;
}
.mp-trust:hover .mp-trust__track { animation-play-state: paused; }
@keyframes mp-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
.mp-trust__item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 32px;
  white-space: nowrap;
  font-size: 0.82rem;
  border-right: 1px solid rgba(255,255,255,0.1);
  color: #f9fafb !important;
}
.mp-trust__item strong { color: #fff !important; }
.mp-trust__item span { color: rgba(249,250,251,0.65) !important; }

/* GRID */
.mp-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  padding: 40px 0;
  align-items: start;
  background: #fff;
}
@media (max-width: 768px) {
  .mp-grid { grid-template-columns: 1fr; gap: 16px; padding: 16px 0; }
}

/* GALLERY */
.mp-gallery__main-wrap { position: relative; border-radius: 16px; overflow: hidden; background: #f3f4f6; aspect-ratio: 1; }
.mp-gallery__main { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── FASE 2: galeria compacta en móvil para que el buybox sea visible above the fold ── */
@media (max-width: 768px) {
  .mp-gallery__main-wrap { aspect-ratio: 4/3; border-radius: 12px; }
  .mp-gallery__thumbs { display: none; } /* ocultar thumbs en móvil — el sticky y swipe cubren la navegación */
  .mp-title { font-size: 1.25rem !important; }
  .mp-subtitle { font-size: 0.88rem !important; }
  .mp-price-current { font-size: 1.5rem !important; }
  .mp-buybox { gap: 12px; }
}

.mp-gallery__badge {
  position: absolute; top: 14px; left: 14px;
  background: #FF5A1F; color: #fff !important;
  font-size: 0.75rem; font-weight: 700;
  padding: 4px 10px; border-radius: 20px;
}
.mp-gallery__counter {
  position: absolute; bottom: 12px; right: 12px;
  background: rgba(0,0,0,0.5); color: #fff !important;
  font-size: 0.75rem; padding: 3px 8px; border-radius: 20px;
}
.mp-gallery__thumbs { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
.mp-thumb-btn {
  width: 72px; height: 72px; border-radius: 10px;
  overflow: hidden; border: 2px solid transparent;
  background: #f3f4f6; cursor: pointer; padding: 0;
  transition: border-color .15s; flex-shrink: 0;
}
.mp-thumb-btn.active, .mp-thumb-btn:hover { border-color: #FF5A1F; }
.mp-thumb-btn img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* BUYBOX */
.mp-buybox { display: flex; flex-direction: column; gap: 16px; background: #fff; }
.mp-vendor { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af !important; margin: 0; }
.mp-title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; line-height: 1.2; margin: 0; color: #111827 !important; }
.mp-subtitle { font-size: 0.95rem; color: #6b7280 !important; margin: 0; }

.mp-price-wrap { display: flex; flex-direction: column; gap: 2px; }
.mp-price-compare { font-size: 0.9rem; color: #9ca3af !important; text-decoration: line-through; margin: 0; }
.mp-price-current { font-size: 1.8rem; font-weight: 800; color: #111827 !important; margin: 0; display: flex; align-items: center; gap: 10px; }
.mp-price-badge { background: #FF5A1F; color: #fff !important; font-size: 0.75rem; font-weight: 700; padding: 3px 8px; border-radius: 20px; }
.mp-price-tax { font-size: 0.75rem; color: #9ca3af !important; margin: 0; }

.mp-rating { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; color: #374151 !important; text-decoration: none; }
.mp-stars { color: #f59e0b !important; display: flex; gap: 1px; }

.mp-bullets { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; }
.mp-bullet { display: flex; align-items: center; gap: 8px; font-size: 0.88rem; color: #374151 !important; }
.mp-bullet__check {
  width: 18px; height: 18px; border-radius: 50%;
  background: #FF5A1F; color: #fff !important;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}

.mp-variant-label { font-size: 0.85rem; font-weight: 600; margin: 0 0 8px; color: #111827 !important; }
.mp-variant-options { display: flex; gap: 8px; flex-wrap: wrap; }
.mp-variant-btn {
  padding: 6px 14px; border-radius: 8px;
  border: 1px solid #d1d5db; background: #fff;
  font-size: 0.85rem; cursor: pointer; transition: all .15s;
  color: #374151 !important;
}
.mp-variant-btn.active, .mp-variant-btn:hover {
  border-color: #FF5A1F; background: #fff7f4; color: #FF5A1F !important; font-weight: 600;
}

.mp-qty-label { font-size: 0.8rem; font-weight: 600; color: #6b7280 !important; text-transform: uppercase; letter-spacing: 0.05em; }
.mp-atc-row { display: flex; gap: 10px; }
.mp-qty { display: flex; align-items: center; border: 1px solid #d1d5db; border-radius: 10px; overflow: hidden; }
.mp-qty-btn { width: 40px; height: 48px; background: #f9fafb; border: none; font-size: 1.2rem; cursor: pointer; color: #111827 !important; }
.mp-qty-btn:hover { background: #f3f4f6; }
.mp-qty-input { width: 44px; height: 48px; border: none; text-align: center; font-size: 1rem; font-weight: 600; color: #111827 !important; background: #fff; -moz-appearance: textfield; }
.mp-qty-input::-webkit-inner-spin-button, .mp-qty-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.mp-atc-btn {
  flex: 1; height: 48px; background: #FF5A1F; color: #fff !important;
  border: none; border-radius: 10px; font-size: 1rem; font-weight: 700;
  cursor: pointer; transition: opacity .15s, transform .1s;
}
.mp-atc-btn:hover { opacity: 0.9; }
.mp-atc-btn:active { transform: scale(0.98); }
.mp-atc-btn:disabled { background: #9ca3af; cursor: not-allowed; }

.mp-payments { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.mp-pay-icon {
  background: #f3f4f6; border-radius: 4px;
  padding: 3px 7px; font-size: 0.68rem; font-weight: 700;
  color: #374151 !important;
}

.mp-accordion { border-top: 1px solid #e5e7eb; }
.mp-accordion:last-child { border-bottom: 1px solid #e5e7eb; }
.mp-accordion-btn {
  width: 100%; display: flex; justify-content: space-between; align-items: center;
  padding: 14px 0; background: none; border: none; cursor: pointer;
  font-size: 0.9rem; font-weight: 600; color: #111827 !important; text-align: left;
}
.mp-accordion-btn svg { transition: transform .2s; flex-shrink: 0; color: #374151 !important; }
.mp-accordion-btn[aria-expanded="true"] svg { transform: rotate(180deg); }
.mp-accordion-content { display: none; padding: 0 0 14px; font-size: 0.88rem; color: #6b7280 !important; line-height: 1.6; }
.mp-accordion-content.open { display: block; }

/* BENEFITS BAR */
.mp-benefits {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: #e5e7eb;
  border-top: 1px solid #e5e7eb;
  border-bottom: 1px solid #e5e7eb;
}
@media (max-width: 640px) { .mp-benefits { grid-template-columns: repeat(2, 1fr); } }
.mp-benefit { background: #f9fafb; padding: 20px 16px; text-align: center; }
.mp-benefit__icon { font-size: 1.6rem; margin-bottom: 6px; }
.mp-benefit__title { font-size: 0.85rem; font-weight: 700; margin: 0 0 2px; color: #111827 !important; }
.mp-benefit__sub { font-size: 0.75rem; color: #6b7280 !important; margin: 0; }

/* STATS */
.mp-stats { background: #fff; padding: 48px 0; border-bottom: 1px solid #e5e7eb; }
.mp-stats__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; text-align: center; }
@media (max-width: 640px) { .mp-stats__grid { grid-template-columns: 1fr; gap: 16px; } }
.mp-stat__value { font-size: 2.2rem; font-weight: 900; color: #FF5A1F !important; margin: 0 0 4px; }
.mp-stat__label { font-size: 0.85rem; color: #6b7280 !important; margin: 0; }

/* TESTIMONIALS */
.mp-testimonials { padding: 56px 0; background: #f9fafb; }
.mp-section-tag { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #FF5A1F !important; margin: 0 0 8px; }
.mp-section-heading { font-size: clamp(1.3rem, 2.5vw, 1.8rem); font-weight: 800; margin: 0 0 8px; color: #111827 !important; }
.mp-section-sub { font-size: 0.9rem; color: #6b7280 !important; margin: 0 0 32px; }
.mp-testimonials-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
@media (max-width: 640px) { .mp-testimonials-grid { grid-template-columns: 1fr; } }
.mp-testimonial { background: #fff; border-radius: 14px; padding: 22px; border: 1px solid #e5e7eb; }
.mp-testimonial__stars { color: #f59e0b !important; font-size: 0.85rem; margin-bottom: 10px; }
.mp-testimonial__text { font-size: 0.88rem; color: #374151 !important; line-height: 1.6; margin: 0 0 14px; font-style: italic; }
.mp-testimonial__author { display: flex; align-items: center; gap: 8px; }
.mp-testimonial__avatar {
  width: 36px; height: 36px; border-radius: 50%;
  background: #FF5A1F; color: #fff !important;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem; font-weight: 700; flex-shrink: 0;
}
.mp-testimonial__name { font-size: 0.82rem; font-weight: 700; margin: 0; color: #111827 !important; }
.mp-testimonial__meta { font-size: 0.75rem; color: #9ca3af !important; margin: 0; }
.mp-verified { font-size: 0.7rem; color: #16a34a !important; font-weight: 600; }

/* GUARANTEE */
.mp-guarantee { background: #fff7ed; padding: 56px 0; border-top: 3px solid #FF5A1F; }
.mp-guarantee__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
@media (max-width: 768px) { .mp-guarantee__inner { grid-template-columns: 1fr; gap: 24px; } }
.mp-guarantee__badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: #FF5A1F; color: #fff !important;
  font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
  padding: 6px 14px; border-radius: 20px; margin-bottom: 16px;
}
.mp-guarantee__heading { font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 800; margin: 0 0 10px; color: #111827 !important; }
.mp-guarantee__sub { font-size: 0.9rem; color: #6b7280 !important; line-height: 1.6; margin: 0 0 24px; }
.mp-guarantee__steps { display: flex; flex-direction: column; gap: 14px; }
.mp-guarantee__step { display: flex; align-items: flex-start; gap: 12px; }
.mp-guarantee__step-num {
  width: 28px; height: 28px; border-radius: 50%;
  background: #FF5A1F; color: #fff !important;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.78rem; font-weight: 800; flex-shrink: 0;
}
.mp-guarantee__step-title { font-size: 0.88rem; font-weight: 700; margin: 0 0 2px; color: #111827 !important; }
.mp-guarantee__step-text { font-size: 0.82rem; color: #6b7280 !important; margin: 0; }
.mp-guarantee__visual {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; gap: 16px;
  background: #fff; border-radius: 20px;
  padding: 40px; text-align: center; border: 2px solid #fed7aa;
}
.mp-guarantee__icon { font-size: 4rem; }
.mp-guarantee__visual-text { font-size: 1.2rem; font-weight: 800; color: #111827 !important; margin: 0; }
.mp-guarantee__visual-sub { font-size: 0.85rem; color: #6b7280 !important; margin: 0; }

/* FAQ */
.mp-faq { padding: 56px 0; background: #fff; }
.mp-faq__list { display: flex; flex-direction: column; gap: 0; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb; }
.mp-faq__item { border-bottom: 1px solid #e5e7eb; }
.mp-faq__item:last-child { border-bottom: none; }
.mp-faq__q {
  width: 100%; display: flex; justify-content: space-between; align-items: center;
  padding: 18px 20px; background: #fff; border: none;
  font-size: 0.92rem; font-weight: 700; color: #111827 !important;
  cursor: pointer; text-align: left; gap: 12px;
}
.mp-faq__q svg { flex-shrink: 0; transition: transform .2s; color: #FF5A1F !important; }
.mp-faq__q[aria-expanded="true"] svg { transform: rotate(180deg); }
.mp-faq__a { display: none; padding: 0 20px 18px; font-size: 0.88rem; color: #6b7280 !important; line-height: 1.7; }
.mp-faq__a.open { display: block; }

/* CTA BANNER */
.mp-cta-banner { background: #111827 !important; color: #fff !important; padding: 56px 0; text-align: center; }
.mp-cta-banner__icon { font-size: 2.5rem; margin-bottom: 12px; }
.mp-cta-banner__heading { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 900; margin: 0 0 10px; color: #fff !important; }
.mp-cta-banner__text { font-size: 0.95rem; color: #9ca3af !important; margin: 0 0 28px; }
.mp-cta-banner__btn {
  display: inline-block; background: #FF5A1F; color: #fff !important;
  font-size: 1.05rem; font-weight: 800; padding: 16px 48px; border-radius: 12px;
  border: none; cursor: pointer; transition: opacity .15s, transform .1s;
}
.mp-cta-banner__btn:hover { opacity: 0.9; }
.mp-cta-banner__trust { font-size: 0.78rem; color: #6b7280 !important; margin: 16px 0 0; }

/* STICKY ATC — ARRIBA */
.mp-sticky {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #fff !important;
  border-bottom: 1px solid #e5e7eb;
  box-shadow: 0 4px 16px rgba(0,0,0,0.10);
  transform: translateY(-100%);
  transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
}
.mp-sticky.visible { transform: translateY(0); }
.mp-sticky__inner {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; padding: 10px 20px;
  max-width: 1200px; margin: 0 auto;
}
.mp-sticky__info { display: flex; align-items: center; gap: 10px; min-width: 0; }
.mp-sticky__img { width: 48px; height: 48px; border-radius: 8px; object-fit: cover; flex-shrink: 0; }
.mp-sticky__title { font-size: 0.85rem; font-weight: 700; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; color: #111827 !important; }
.mp-sticky__price { font-size: 0.85rem; color: #111827 !important; margin: 0; }
.mp-sticky__btn {
  background: #FF5A1F; color: #fff !important;
  border: none; border-radius: 8px;
  padding: 10px 24px; font-size: 0.9rem; font-weight: 700;
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
}
@media (max-width: 480px) {
  .mp-sticky__title { max-width: 100px; }
  .mp-sticky__btn { padding: 10px 16px; font-size: 0.82rem; }
}
</style>

<!-- TRUST BAR -->
<div class="mp-trust" aria-label="Ventajas de compra">
  <div class="mp-trust__track" aria-hidden="true">
    <div class="mp-trust__item"><strong>Envío gratis</strong><span>En pedidos +50€</span></div>
    <div class="mp-trust__item"><strong>Devolución 30 días</strong><span>Sin preguntas</span></div>
    <div class="mp-trust__item"><strong>Pago seguro</strong><span>Visa, MC, PayPal, Bizum</span></div>
    <div class="mp-trust__item"><strong>4.9 ★</strong><span>+127 reseñas verificadas</span></div>
    <div class="mp-trust__item"><strong>Envío gratis</strong><span>En pedidos +50€</span></div>
    <div class="mp-trust__item"><strong>Devolución 30 días</strong><span>Sin preguntas</span></div>
    <div class="mp-trust__item"><strong>Pago seguro</strong><span>Visa, MC, PayPal, Bizum</span></div>
    <div class="mp-trust__item"><strong>4.9 ★</strong><span>+127 reseñas verificadas</span></div>
  </div>
</div>

<div class="mp">
  <div class="wrap">
    <div class="mp-grid">
      <div class="mp-gallery">
        <div class="mp-gallery__main-wrap">
          {%- assign featured_media = cv.featured_media | default: product.featured_media -%}
          {%- if featured_media -%}
            <img id="mp-main-img" src="{{ featured_media | image_url: width: 1200 }}" alt="{{ product.title | escape }}" class="mp-gallery__main" loading="eager" fetchpriority="high" width="900" height="900">
          {%- else -%}
            <div class="mp-gallery__main" style="background:#f3f4f6;"></div>
          {%- endif -%}
          {%- if cv.compare_at_price > cv.price -%}
            <span class="mp-gallery__badge">-{{ savings_pct }}%</span>
          {%- endif -%}
          {%- if product.media.size > 1 -%}
            <span class="mp-gallery__counter" id="mp-counter">1 / {{ product.media.size }}</span>
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="mp-gallery__thumbs">
            {%- for media in product.media limit: 8 -%}
              <button type="button" class="mp-thumb-btn{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index }}" data-src="{{ media | image_url: width: 1200 }}" aria-label="Ver imagen {{ forloop.index }}">
                <img src="{{ media | image_url: width: 200 }}" alt="" loading="lazy" width="72" height="72">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="mp-buybox" id="mp-buybox">
        <p class="mp-vendor">{{ product.vendor | default: shop.name }}</p>
        <h1 class="mp-title">{{ product.title }}</h1>
        {%- if section.settings.subtitle != blank -%}
          <p class="mp-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        <div class="mp-price-wrap">
          {%- if cv.compare_at_price > cv.price -%}
            <p class="mp-price-compare">{{ cv.compare_at_price | money }}</p>
          {%- endif -%}
          <p class="mp-price-current" id="mp-price">
            {{ cv.price | money }}
            {%- if savings_pct -%}<span class="mp-price-badge">-{{ savings_pct }}%</span>{%- endif -%}
          </p>
          <p class="mp-price-tax">IVA incluido{%- if section.settings.shipping_text != blank -%} &middot; {{ section.settings.shipping_text }}{%- endif -%}</p>
        </div>

        <a href="#mp-reviews" class="mp-rating">
          <span class="mp-stars" aria-hidden="true">★★★★★</span>
          <span>{{ section.settings.review_count_text | default: '4.9 · 127 reseñas' }}</span>
        </a>

        {%- if bullet_blocks.size > 0 -%}
          <ul class="mp-bullets">
            {%- for block in bullet_blocks -%}
              <li class="mp-bullet" {{ block.shopify_attributes }}>
                <span class="mp-bullet__check" aria-hidden="true">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {{ block.settings.text }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div>
              <p class="mp-variant-label">{{ option.name }}: <span id="mp-opt-{{ forloop.index }}">{{ option.selected_value }}</span></p>
              <div class="mp-variant-options">
                {%- for value in option.values -%}
                  <button type="button" class="mp-variant-btn{% if value == option.selected_value %} active{% endif %}" data-opt="{{ forloop.parentloop.index0 }}" data-val="{{ value }}">{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <div>
          <p class="mp-qty-label">Cantidad</p>
          <div class="mp-atc-row" id="mp-atc-anchor">
            <div class="mp-qty">
              <button type="button" class="mp-qty-btn" id="mp-dec" aria-label="Reducir">−</button>
              <input type="number" class="mp-qty-input" id="mp-qty" value="1" min="1" max="99" aria-label="Cantidad">
              <button type="button" class="mp-qty-btn" id="mp-inc" aria-label="Aumentar">+</button>
            </div>
            <button type="button" class="mp-atc-btn" id="mp-atc" data-variant-id="{{ cv.id }}" {% unless cv.available %}disabled{% endunless %}>
              {%- if cv.available -%}Agregar al carrito{%- else -%}Agotado{%- endif -%}
            </button>
          </div>
        </div>

        <div class="mp-payments">
          <span class="mp-pay-icon">VISA</span>
          <span class="mp-pay-icon">MC</span>
          <span class="mp-pay-icon">PayPal</span>
          <span class="mp-pay-icon">Bizum</span>
          <span class="mp-pay-icon">Shop Pay</span>
        </div>

        <div>
          {%- if product.description != blank -%}
            <div class="mp-accordion">
              <button type="button" class="mp-accordion-btn" aria-expanded="false">Detalles
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="mp-accordion-content">{{ product.description | strip_html | truncate: 400 }}</div>
            </div>
          {%- endif -%}
