        <p class="mp-sticky__title">{{ product.title | truncate: 30 }}</p>
        <p class="mp-sticky__price" id="mp-sticky-price">{{ cv.price | money }}</p>
      </div>
    </div>
    <button type="button" class="mp-sticky__btn" id="mp-sticky-atc" data-variant-id="{{ cv.id }}" {% unless cv.available %}disabled{% endunless %}>
      Agregar al carrito
    </button>
  </div>
</div>

<script>
(function() {
  var variants = {{ product.variants | json }};
  var mainImg = document.getElementById('mp-main-img');
  var counter = document.getElementById('mp-counter');

  document.querySelectorAll('.mp-thumb-btn').forEach(function(btn, i) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.mp-thumb-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      if (mainImg && btn.dataset.src) mainImg.src = btn.dataset.src;
      if (counter) counter.textContent = (i+1) + ' / ' + document.querySelectorAll('.mp-thumb-btn').length;
    });
  });

  var qtyInput = document.getElementById('mp-qty');
  var decBtn = document.getElementById('mp-dec');
  var incBtn = document.getElementById('mp-inc');
  if (decBtn) decBtn.addEventListener('click', function() { var v = parseInt(qtyInput.value,10)||1; if(v>1) qtyInput.value=v-1; });
  if (incBtn) incBtn.addEventListener('click', function() { var v = parseInt(qtyInput.value,10)||1; qtyInput.value=v+1; });

  function addToCart(variantId, qty, btn, orig) {
    btn.textContent = 'Añadiendo…'; btn.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({id: parseInt(variantId,10), quantity: qty})
    }).then(function(r){return r.json();}).then(function(){
      btn.textContent = '✓ Añadido';
      document.dispatchEvent(new CustomEvent('cart:updated'));
      setTimeout(function(){ btn.textContent=orig; btn.disabled=false; }, 2200);
    }).catch(function(){ btn.textContent=orig; btn.disabled=false; });
  }

  var atcBtn = document.getElementById('mp-atc');
  if (atcBtn) atcBtn.addEventListener('click', function() {
    addToCart(atcBtn.dataset.variantId, parseInt(qtyInput?qtyInput.value:1,10)||1, atcBtn, 'Agregar al carrito');
  });

  var ctaBtn = document.getElementById('mp-cta-atc');
  if (ctaBtn) ctaBtn.addEventListener('click', function() {
    var vid = atcBtn ? atcBtn.dataset.variantId : '{{ cv.id }}';
    addToCart(vid, 1, ctaBtn, 'Añadir al carrito');
  });

  var stickyBtn = document.getElementById('mp-sticky-atc');
  if (stickyBtn) stickyBtn.addEventListener('click', function() {
    addToCart(stickyBtn.dataset.variantId, parseInt(qtyInput?qtyInput.value:1,10)||1, stickyBtn, 'Agregar al carrito');
  });

  var anchor = document.getElementById('mp-atc-anchor');
  var sticky = document.getElementById('mp-sticky');

  if (anchor && sticky) {
    function updateSticky() {
      var rect = anchor.getBoundingClientRect();
      var anchorGone = rect.bottom < 0;
      sticky.classList.toggle('visible', anchorGone);
    }

    window.addEventListener('scroll', updateSticky, { passive: true });
  }

  document.querySelectorAll('.mp-accordion-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var open = btn.getAttribute('aria-expanded')==='true';
      btn.setAttribute('aria-expanded', !open);
      btn.nextElementSibling.classList.toggle('open', !open);
    });
  });

  document.querySelectorAll('.mp-faq__q').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var open = btn.getAttribute('aria-expanded')==='true';
      btn.setAttribute('aria-expanded', !open);
      btn.nextElementSibling.classList.toggle('open', !open);
    });
  });

  document.querySelectorAll('.mp-variant-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var optIdx = parseInt(btn.dataset.opt, 10);
      document.querySelectorAll('.mp-variant-btn[data-opt="'+optIdx+'"]').forEach(function(b){b.classList.remove('active');});
      btn.classList.add('active');
      var lbl = document.getElementById('mp-opt-'+(optIdx+1));
      if (lbl) lbl.textContent = btn.dataset.val;
      var selected = {};
      document.querySelectorAll('.mp-variant-btn.active').forEach(function(b){ selected[parseInt(b.dataset.opt,10)]=b.dataset.val; });
      var match = variants.find(function(v){ return v.options.every(function(o,i){ return selected[i]===undefined||selected[i]===o; }); });
      if (match) {
        if (atcBtn) { atcBtn.dataset.variantId=match.id; atcBtn.disabled=!match.available; atcBtn.textContent=match.available?'Agregar al carrito':'Agotado'; }
        if (stickyBtn) { stickyBtn.dataset.variantId=match.id; stickyBtn.disabled=!match.available; }
        var priceEl = document.getElementById('mp-price');
        if (priceEl) priceEl.childNodes[0].textContent = (match.price/100).toFixed(2).replace('.',',')+' €';
      }
    });
  });
})();
</script>

