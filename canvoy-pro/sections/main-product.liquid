{%- assign cv = product.selected_or_first_available_variant -%}
{%- if cv.compare_at_price > cv.price -%}
  {%- assign savings_amount = cv.compare_at_price | minus: cv.price -%}
  {%- assign savings_pct = savings_amount | times: 100 | divided_by: cv.compare_at_price -%}
{%- endif -%}
{%- assign bullet_blocks  = section.blocks | where: 'type', 'bullet' -%}
{%- assign bundle_blocks  = section.blocks | where: 'type', 'bundle' -%}

<style>
/* ── BASE ── */
.mp { font-family: inherit; color: #111827; background: #fff; }
.mp .wrap { max-width: 1200px; margin: 0 auto; padding: 0 20px; }

/* TRUST BAR */
.mp-trust { background: #111827 !important; color: #f9fafb !important; overflow: hidden; position: relative; }
.mp-trust__track { display: flex; gap: 0; animation: mp-scroll 22s linear infinite; width: max-content; }
.mp-trust:hover .mp-trust__track { animation-play-state: paused; }
@keyframes mp-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
.mp-trust__item { display: flex; align-items: center; gap: 8px; padding: 10px 32px; white-space: nowrap; font-size: 0.82rem; border-right: 1px solid rgba(255,255,255,0.1); color: #f9fafb !important; }
.mp-trust__item strong { color: #fff !important; }
.mp-trust__item span { color: rgba(249,250,251,0.65) !important; }

/* GRID */
.mp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; padding: 40px 0; align-items: start; background: #fff; }
@media (max-width: 768px) { .mp-grid { grid-template-columns: 1fr; gap: 16px; padding: 16px 0; } }

/* GALLERY */
.mp-gallery__main-wrap { position: relative; border-radius: 16px; overflow: hidden; background: #f3f4f6; aspect-ratio: 1; }
.mp-gallery__main { width: 100%; height: 100%; object-fit: cover; display: block; }
@media (max-width: 768px) {
  .mp-gallery__main-wrap { aspect-ratio: 4/3; border-radius: 12px; }
  .mp-gallery__thumbs { display: none; }
  .mp-title { font-size: 1.25rem !important; }
  .mp-subtitle { font-size: 0.85rem !important; }
  .mp-price-current { font-size: 1.5rem !important; }
  .mp-buybox { gap: 12px; }
}
.mp-gallery__badge { position: absolute; top: 14px; left: 14px; background: #FF5A1F; color: #fff !important; font-size: 0.75rem; font-weight: 700; padding: 4px 10px; border-radius: 20px; }
.mp-gallery__counter { position: absolute; bottom: 12px; right: 12px; background: rgba(0,0,0,0.5); color: #fff !important; font-size: 0.75rem; padding: 3px 8px; border-radius: 20px; }
.mp-gallery__thumbs { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
.mp-thumb-btn { width: 72px; height: 72px; border-radius: 10px; overflow: hidden; border: 2px solid transparent; background: #f3f4f6; cursor: pointer; padding: 0; transition: border-color .15s; flex-shrink: 0; }
.mp-thumb-btn.active, .mp-thumb-btn:hover { border-color: #FF5A1F; }
.mp-thumb-btn img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* BUYBOX */
.mp-buybox { display: flex; flex-direction: column; gap: 16px; background: #fff; }
.mp-vendor { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af !important; margin: 0; }
.mp-title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; line-height: 1.2; margin: 0; color: #111827 !important; }
.mp-subtitle { font-size: 0.88rem; color: #6b7280 !important; margin: 0; }
.mp-rating { display: flex; align-items: center; gap: 6px; font-size: 0.85rem; color: #374151 !important; text-decoration: none; }
.mp-stars { color: #f59e0b !important; display: flex; gap: 1px; }
.mp-price-wrap { display: flex; flex-direction: column; gap: 2px; }
.mp-price-compare { font-size: 0.9rem; color: #9ca3af !important; text-decoration: line-through; margin: 0; }
.mp-price-current { font-size: 1.8rem; font-weight: 800; color: #111827 !important; margin: 0; display: flex; align-items: center; gap: 10px; }
.mp-price-badge { background: #FF5A1F; color: #fff !important; font-size: 0.75rem; font-weight: 700; padding: 3px 8px; border-radius: 20px; }
.mp-price-tax { font-size: 0.75rem; color: #9ca3af !important; margin: 0; }

.mp-stock { display: inline-flex; align-items: center; gap: 6px; font-size: 0.8rem; font-weight: 600; color: #16a34a !important; }
.mp-stock__dot { width: 8px; height: 8px; border-radius: 50%; background: #16a34a; flex-shrink: 0; animation: mp-pulse 2s ease-in-out infinite; }
@keyframes mp-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

.mp-bullets { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
.mp-bullet { display: flex; align-items: center; gap: 10px; font-size: 0.92rem; font-weight: 600; color: #111827 !important; }
.mp-bullet__check { width: 20px; height: 20px; border-radius: 50%; background: #FF5A1F; color: #fff !important; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

/* variant pills */
.mp-variant-label { font-size: 0.85rem; font-weight: 600; margin: 0 0 8px; color: #111827 !important; }
.mp-variant-options { display: flex; gap: 8px; flex-wrap: wrap; }
.mp-variant-btn { padding: 6px 14px; border-radius: 8px; border: 1px solid #d1d5db; background: #fff; font-size: 0.85rem; cursor: pointer; transition: all .15s; color: #374151 !important; }
.mp-variant-btn.active, .mp-variant-btn:hover { border-color: #FF5A1F; background: #fff7f4; color: #FF5A1F !important; font-weight: 600; }

/* BUNDLE CARDS */
.mp-bundle-section { display: flex; flex-direction: column; gap: 10px; }
.mp-bundle-heading { font-size: 0.72rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #FF5A1F !important; background: #fff7f4; border: 1px solid #fed7aa; border-radius: 8px; padding: 7px 14px; text-align: center; margin: 0; }
.mp-bundle-cards { display: flex; flex-direction: column; gap: 8px; }
.mp-bundle-card { position: relative; display: flex; align-items: center; gap: 14px; border: 2px solid #e5e7eb; border-radius: 12px; padding: 14px 16px; cursor: pointer; background: #fff; transition: border-color .15s, background .15s; text-align: left; width: 100%; }
.mp-bundle-card:hover { border-color: #fdba74; background: #fffbf7; }
.mp-bundle-card.active { border-color: #FF5A1F; background: #fff7f4; box-shadow: 0 0 0 3px rgba(255,90,31,0.10); }
.mp-bundle-card:focus-visible { outline: 2px solid #FF5A1F; outline-offset: 2px; }
.mp-bundle-card__badge { position: absolute; top: -11px; left: 14px; background: #FF5A1F; color: #fff !important; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 10px; border-radius: 20px; white-space: nowrap; }
.mp-bundle-card__radio { width: 20px; height: 20px; border-radius: 50%; border: 2px solid #d1d5db; background: #fff; flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: border-color .15s; }
.mp-bundle-card.active .mp-bundle-card__radio { border-color: #FF5A1F; background: #FF5A1F; }
.mp-bundle-card__radio-dot { width: 8px; height: 8px; border-radius: 50%; background: #fff; opacity: 0; transition: opacity .15s; }
.mp-bundle-card.active .mp-bundle-card__radio-dot { opacity: 1; }
.mp-bundle-card__info { flex: 1; min-width: 0; }
.mp-bundle-card__title { font-size: 0.9rem; font-weight: 700; color: #111827 !important; margin: 0 0 2px; display: block; }
.mp-bundle-card__unit { font-size: 0.75rem; color: #6b7280 !important; margin: 0; display: block; }
.mp-bundle-card__price-wrap { text-align: right; flex-shrink: 0; }
.mp-bundle-card__price { font-size: 1.05rem; font-weight: 900; color: #111827 !important; margin: 0; display: block; }
.mp-bundle-card.active .mp-bundle-card__price { color: #FF5A1F !important; }
.mp-bundle-card__compare { font-size: 0.75rem; color: #9ca3af !important; text-decoration: line-through; margin: 0; display: block; }
.mp-bundle-card__saving { font-size: 0.7rem; font-weight: 700; color: #16a34a !important; margin: 0; display: block; }

/* ATC */
.mp-qty-label { font-size: 0.8rem; font-weight: 600; color: #6b7280 !important; text-transform: uppercase; letter-spacing: 0.05em; }
.mp-atc-row { display: flex; gap: 10px; }
.mp-qty { display: flex; align-items: center; border: 1px solid #d1d5db; border-radius: 10px; overflow: hidden; }
.mp-qty-btn { width: 40px; height: 48px; background: #f9fafb; border: none; font-size: 1.2rem; cursor: pointer; color: #111827 !important; }
.mp-qty-btn:hover { background: #f3f4f6; }
.mp-qty-input { width: 44px; height: 48px; border: none; text-align: center; font-size: 1rem; font-weight: 600; color: #111827 !important; background: #fff; -moz-appearance: textfield; }
.mp-qty-input::-webkit-inner-spin-button, .mp-qty-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.mp-atc-btn { flex: 1; height: 52px; background: #FF5A1F; color: #fff !important; border: none; border-radius: 10px; font-size: 1rem; font-weight: 700; cursor: pointer; transition: opacity .15s, transform .1s; letter-spacing: 0.01em; }
.mp-atc-btn:hover { opacity: 0.9; }
.mp-atc-btn:active { transform: scale(0.98); }
.mp-atc-btn:disabled { background: #9ca3af; cursor: not-allowed; }

/* URGENCY */
.mp-urgency-wrap { display: flex; flex-direction: column; gap: 8px; }
.mp-viral-badge { display: inline-flex; align-items: center; gap: 8px; background: linear-gradient(135deg, #111827 0%, #1f2937 100%); color: #fff !important; border-radius: 8px; padding: 7px 14px; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; width: fit-content; }
.mp-viral-badge__dot { width: 7px; height: 7px; border-radius: 50%; background: #FF5A1F; flex-shrink: 0; animation: mp-pulse 1s ease-in-out infinite; }
.mp-viral-badge__sep { width: 1px; height: 12px; background: rgba(255,255,255,0.25); flex-shrink: 0; }
.mp-viral-badge__fire { font-size: 0.9rem; }
.mp-countdown { display: flex; align-items: center; gap: 10px; background: #fff7ed; border: 1px solid #fed7aa; border-radius: 10px; padding: 10px 14px; }
.mp-countdown__label { font-size: 0.78rem; font-weight: 600; color: #92400e !important; white-space: nowrap; flex-shrink: 0; }
.mp-countdown__timer { display: flex; align-items: center; gap: 4px; margin-left: auto; }
.mp-countdown__block { display: flex; flex-direction: column; align-items: center; background: #111827; border-radius: 6px; padding: 4px 8px; min-width: 36px; }
.mp-countdown__num { font-size: 1.05rem; font-weight: 900; color: #fff !important; line-height: 1; font-variant-numeric: tabular-nums; }
.mp-countdown__unit { font-size: 0.55rem; font-weight: 600; color: #9ca3af !important; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 1px; }
.mp-countdown__sep { font-size: 1rem; font-weight: 900; color: #FF5A1F !important; line-height: 1; margin-bottom: 8px; }
.mp-fomo { display: flex; align-items: center; gap: 8px; background: #fff7ed; border: 1px solid #fed7aa; border-radius: 8px; padding: 8px 12px; font-size: 0.8rem; color: #92400e !important; }
.mp-fomo__dot { width: 8px; height: 8px; border-radius: 50%; background: #f97316; flex-shrink: 0; animation: mp-pulse 1.4s ease-in-out infinite; }
.mp-fomo strong { color: #c2410c !important; }

.mp-trust-mini { display: flex; gap: 0; border: 1px solid #e5e7eb; border-radius: 10px; overflow: hidden; }
.mp-trust-mini__item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; padding: 10px 6px; text-align: center; border-right: 1px solid #e5e7eb; font-size: 0.7rem; color: #374151 !important; line-height: 1.3; }
.mp-trust-mini__item:last-child { border-right: none; }
.mp-trust-mini__icon { font-size: 1.1rem; }
.mp-trust-mini__label { font-weight: 700; font-size: 0.7rem; color: #111827 !important; }
.mp-trust-mini__sub { font-size: 0.65rem; color: #6b7280 !important; }

/* PAYMENT LOGOS */
.mp-payments { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }
.mp-pay-logo { height: 24px; border-radius: 4px; display: inline-flex; align-items: center; justify-content: center; background: #f3f4f6; padding: 3px 7px; }
.mp-pay-logo svg { height: 16px; width: auto; display: block; }

/* ACCORDION */
.mp-accordion { border-top: 1px solid #e5e7eb; }
.mp-accordion:last-child { border-bottom: 1px solid #e5e7eb; }
.mp-accordion-btn { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 14px 0; background: none; border: none; cursor: pointer; font-size: 0.9rem; font-weight: 600; color: #111827 !important; text-align: left; }
.mp-accordion-btn svg { transition: transform .2s; flex-shrink: 0; color: #374151 !important; }
.mp-accordion-btn[aria-expanded="true"] svg { transform: rotate(180deg); }
.mp-accordion-content { display: none; padding: 0 0 14px; font-size: 0.88rem; color: #6b7280 !important; line-height: 1.6; }
.mp-accordion-content.open { display: block; }

/* DETALLES mejorado */
.mp-details-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 7px; }
.mp-details-list li { display: flex; align-items: flex-start; gap: 8px; font-size: 0.85rem; color: #374151 !important; line-height: 1.5; }
.mp-details-list li::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #FF5A1F; flex-shrink: 0; margin-top: 6px; }

/* BENEFITS con imagen central */
.mp-benefits { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #e5e7eb; border-top: 1px solid #e5e7eb; border-bottom: 1px solid #e5e7eb; }
@media (max-width: 640px) { .mp-benefits { grid-template-columns: repeat(2, 1fr); } }
.mp-benefit { background: #f9fafb; padding: 20px 16px; text-align: center; }
.mp-benefit__icon { font-size: 1.6rem; margin-bottom: 6px; }
.mp-benefit__title { font-size: 0.85rem; font-weight: 700; margin: 0 0 2px; color: #111827 !important; }
.mp-benefit__sub { font-size: 0.75rem; color: #6b7280 !important; margin: 0; }

/* LIFESTYLE IMAGE STRIP */
.mp-lifestyle-strip { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
@media (max-width: 640px) { .mp-lifestyle-strip { grid-template-columns: 1fr; } }
.mp-lifestyle-strip__img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }

/* STATS con imagen lateral */
.mp-stats { background: #fff; padding: 48px 0; border-bottom: 1px solid #e5e7eb; }
.mp-stats__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
@media (max-width: 768px) { .mp-stats__inner { grid-template-columns: 1fr; gap: 24px; } }
.mp-stats__grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
.mp-stat__value { font-size: 2.2rem; font-weight: 900; color: #FF5A1F !important; margin: 0 0 4px; }
.mp-stat__label { font-size: 0.85rem; color: #6b7280 !important; margin: 0; }
.mp-stats__img-wrap { border-radius: 16px; overflow: hidden; aspect-ratio: 4/3; }
.mp-stats__img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
@media (max-width: 768px) { .mp-stats__img-wrap { display: none; } }

.mp-testimonials { padding: 56px 0; background: #f9fafb; }
.mp-section-tag { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #FF5A1F !important; margin: 0 0 8px; }
.mp-section-heading { font-size: clamp(1.3rem, 2.5vw, 1.8rem); font-weight: 800; margin: 0 0 8px; color: #111827 !important; }
.mp-section-sub { font-size: 0.9rem; color: #6b7280 !important; margin: 0 0 32px; }
.mp-testimonials-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
@media (max-width: 640px) { .mp-testimonials-grid { grid-template-columns: 1fr; } }
.mp-testimonial { background: #fff; border-radius: 14px; padding: 22px; border: 1px solid #e5e7eb; }
.mp-testimonial__stars { color: #f59e0b !important; font-size: 0.85rem; margin-bottom: 10px; }
.mp-testimonial__text { font-size: 0.88rem; color: #374151 !important; line-height: 1.6; margin: 0 0 14px; font-style: italic; }
.mp-testimonial__author { display: flex; align-items: center; gap: 8px; }
.mp-testimonial__avatar { width: 36px; height: 36px; border-radius: 50%; background: #FF5A1F; color: #fff !important; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 700; flex-shrink: 0; }
.mp-testimonial__name { font-size: 0.82rem; font-weight: 700; margin: 0; color: #111827 !important; }
.mp-testimonial__meta { font-size: 0.75rem; color: #9ca3af !important; margin: 0; }
.mp-verified { font-size: 0.7rem; color: #16a34a !important; font-weight: 600; }

/* GUARANTEE con imagen */
.mp-guarantee { background: #fff7ed; padding: 56px 0; border-top: 3px solid #FF5A1F; }
.mp-guarantee__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
@media (max-width: 768px) { .mp-guarantee__inner { grid-template-columns: 1fr; gap: 24px; } }
.mp-guarantee__badge { display: inline-flex; align-items: center; gap: 8px; background: #FF5A1F; color: #fff !important; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; padding: 6px 14px; border-radius: 20px; margin-bottom: 16px; }
.mp-guarantee__heading { font-size: clamp(1.4rem, 2.5vw, 1.9rem); font-weight: 800; margin: 0 0 10px; color: #111827 !important; }
.mp-guarantee__sub { font-size: 0.9rem; color: #6b7280 !important; line-height: 1.6; margin: 0 0 24px; }
.mp-guarantee__steps { display: flex; flex-direction: column; gap: 14px; }
.mp-guarantee__step { display: flex; align-items: flex-start; gap: 12px; }
.mp-guarantee__step-num { width: 28px; height: 28px; border-radius: 50%; background: #FF5A1F; color: #fff !important; display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 800; flex-shrink: 0; }
.mp-guarantee__step-title { font-size: 0.88rem; font-weight: 700; margin: 0 0 2px; color: #111827 !important; }
.mp-guarantee__step-text { font-size: 0.82rem; color: #6b7280 !important; margin: 0; }
/* Lado derecho de garantía: imagen real en lugar de badge genérico */
.mp-guarantee__visual { border-radius: 20px; overflow: hidden; aspect-ratio: 4/3; }
.mp-guarantee__visual img { width: 100%; height: 100%; object-fit: cover; display: block; }
@media (max-width: 768px) { .mp-guarantee__visual { display: none; } }

.mp-faq { padding: 56px 0; background: #fff; }
.mp-faq__list { display: flex; flex-direction: column; gap: 0; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb; }
.mp-faq__item { border-bottom: 1px solid #e5e7eb; }
.mp-faq__item:last-child { border-bottom: none; }
.mp-faq__q { width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 18px 20px; background: #fff; border: none; font-size: 0.92rem; font-weight: 700; color: #111827 !important; cursor: pointer; text-align: left; gap: 12px; }
.mp-faq__q svg { flex-shrink: 0; transition: transform .2s; color: #FF5A1F !important; }
.mp-faq__q[aria-expanded="true"] svg { transform: rotate(180deg); }
.mp-faq__a { display: none; padding: 0 20px 18px; font-size: 0.88rem; color: #6b7280 !important; line-height: 1.7; }
.mp-faq__a.open { display: block; }

.mp-cta-banner { background: #111827 !important; color: #fff !important; padding: 56px 0; text-align: center; }
.mp-cta-banner__icon { font-size: 2.5rem; margin-bottom: 12px; }
.mp-cta-banner__heading { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 900; margin: 0 0 10px; color: #fff !important; }
.mp-cta-banner__text { font-size: 0.95rem; color: #9ca3af !important; margin: 0 0 28px; }
.mp-cta-banner__btn { display: inline-block; background: #FF5A1F; color: #fff !important; font-size: 1.05rem; font-weight: 800; padding: 16px 48px; border-radius: 12px; border: none; cursor: pointer; transition: opacity .15s, transform .1s; }
.mp-cta-banner__btn:hover { opacity: 0.9; }
.mp-cta-banner__trust { font-size: 0.78rem; color: #6b7280 !important; margin: 16px 0 0; }

.mp-sticky { position: fixed; top: 0; left: 0; right: 0; z-index: 999; background: #fff !important; border-bottom: 1px solid #e5e7eb; box-shadow: 0 4px 16px rgba(0,0,0,0.10); transform: translateY(-100%); transition: transform 0.3s cubic-bezier(0.4,0,0.2,1); }
.mp-sticky.visible { transform: translateY(0); }
.mp-sticky__inner { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 10px 20px; max-width: 1200px; margin: 0 auto; }
.mp-sticky__info { display: flex; align-items: center; gap: 10px; min-width: 0; }
.mp-sticky__img { width: 48px; height: 48px; border-radius: 8px; object-fit: cover; flex-shrink: 0; }
.mp-sticky__title { font-size: 0.85rem; font-weight: 700; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px; color: #111827 !important; }
.mp-sticky__price { font-size: 0.85rem; color: #111827 !important; margin: 0; }
.mp-sticky__btn { background: #FF5A1F; color: #fff !important; border: none; border-radius: 8px; padding: 10px 24px; font-size: 0.9rem; font-weight: 700; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
@media (max-width: 480px) { .mp-sticky__title { max-width: 100px; } .mp-sticky__btn { padding: 10px 16px; font-size: 0.82rem; } }

/* ── GIFT BANNER ── */
.mp-gift { display: none; align-items: center; gap: 12px; background: linear-gradient(135deg, #052e16 0%, #14532d 100%); border: 1.5px solid #16a34a; border-radius: 12px; padding: 12px 16px; animation: mp-gift-in .25s ease; }
.mp-gift.visible { display: flex; }
@keyframes mp-gift-in { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:translateY(0); } }
.mp-gift__icon { font-size: 1.6rem; flex-shrink: 0; }
.mp-gift__body { flex: 1; min-width: 0; }
.mp-gift__tag { font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: #4ade80 !important; margin: 0 0 2px; }
.mp-gift__name { font-size: 0.88rem; font-weight: 700; color: #fff !important; margin: 0 0 1px; }
.mp-gift__sub { font-size: 0.72rem; color: #86efac !important; margin: 0; }
.mp-gift__price { text-align: right; flex-shrink: 0; }
.mp-gift__free { font-size: 0.95rem; font-weight: 900; color: #4ade80 !important; display: block; }
.mp-gift__was { font-size: 0.7rem; color: #86efac !important; text-decoration: line-through; display: block; }
</style>

<div class="mp-trust" aria-label="Ventajas de compra">
  <div class="mp-trust__track" aria-hidden="true">
    <div class="mp-trust__item"><strong>Envío gratis</strong><span>En pedidos +50€</span></div>
    <div class="mp-trust__item"><strong>Devolución 30 días</strong><span>Sin preguntas</span></div>
    <div class="mp-trust__item"><strong>Pago seguro</strong><span>Visa, MC, PayPal, Bizum</span></div>
    <div class="mp-trust__item"><strong>4.9 ★</strong><span>+127 reseñas verificadas</span></div>
    <div class="mp-trust__item"><strong>Envío gratis</strong><span>En pedidos +50€</span></div>
    <div class="mp-trust__item"><strong>Devolución 30 días</strong><span>Sin preguntas</span></div>
    <div class="mp-trust__item"><strong>Pago seguro</strong><span>Visa, MC, PayPal, Bizum</span></div>
    <div class="mp-trust__item"><strong>4.9 ★</strong><span>+127 reseñas verificadas</span></div>
  </div>
</div>

<div class="mp">
  <div class="wrap">
    <div class="mp-grid">
      <div class="mp-gallery">
        <div class="mp-gallery__main-wrap">
          {%- assign featured_media = cv.featured_media | default: product.featured_media -%}
          {%- if featured_media -%}
            <img id="mp-main-img" src="{{ featured_media | image_url: width: 1200 }}" alt="{{ product.title | escape }}" class="mp-gallery__main" loading="eager" fetchpriority="high" width="900" height="900">
          {%- else -%}
            <div class="mp-gallery__main" style="background:#f3f4f6;"></div>
          {%- endif -%}
          {%- if cv.compare_at_price > cv.price -%}<span class="mp-gallery__badge">-{{ savings_pct }}%</span>{%- endif -%}
          {%- if product.media.size > 1 -%}<span class="mp-gallery__counter" id="mp-counter">1 / {{ product.media.size }}</span>{%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="mp-gallery__thumbs">
            {%- for media in product.media limit: 8 -%}
              <button type="button" class="mp-thumb-btn{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index }}" data-src="{{ media | image_url: width: 1200 }}" aria-label="Ver imagen {{ forloop.index }}">
                <img src="{{ media | image_url: width: 200 }}" alt="" loading="lazy" width="72" height="72">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="mp-buybox" id="mp-buybox">
        {%- if cv.available -%}
        <div class="mp-urgency-wrap">
          <div class="mp-viral-badge">
            <span class="mp-viral-badge__fire">🔥</span>
            <span>Producto viral</span>
            <span class="mp-viral-badge__sep"></span>
            <span class="mp-viral-badge__dot"></span>
            <span>Stock bajo</span>
          </div>
          <div class="mp-countdown" role="timer" aria-live="polite">
            <span class="mp-countdown__label">⏰ Oferta flash — termina en</span>
            <div class="mp-countdown__timer">
              <div class="mp-countdown__block"><span class="mp-countdown__num" id="mp-cd-m">--</span><span class="mp-countdown__unit">min</span></div>
              <span class="mp-countdown__sep">:</span>
              <div class="mp-countdown__block"><span class="mp-countdown__num" id="mp-cd-s">--</span><span class="mp-countdown__unit">seg</span></div>
            </div>
          </div>
        </div>
        {%- endif -%}

        <p class="mp-vendor">{{ product.vendor | default: shop.name }}</p>
        <h1 class="mp-title">{{ product.title }}</h1>
        <a href="#mp-reviews" class="mp-rating">
          <span class="mp-stars">★★★★★</span>
          <span>{{ section.settings.review_count_text }}</span>
        </a>

        <div class="mp-price-wrap">
          {%- if cv.compare_at_price > cv.price -%}<p class="mp-price-compare">{{ cv.compare_at_price | money }}</p>{%- endif -%}
          <p class="mp-price-current" id="mp-price">
            {{ cv.price | money }}
            {%- if savings_pct -%}<span class="mp-price-badge">-{{ savings_pct }}%</span>{%- endif -%}
          </p>
          <p class="mp-price-tax">IVA incluido{%- if section.settings.shipping_text != blank -%} &middot; {{ section.settings.shipping_text }}{%- endif -%}</p>
        </div>

        {%- if cv.available -%}<span class="mp-stock"><span class="mp-stock__dot"></span> En stock — envío en 3–5 días hábiles</span>{%- endif -%}
        {%- if section.settings.subtitle != blank -%}<p class="mp-subtitle">{{ section.settings.subtitle }}</p>{%- endif -%}

        {%- if bullet_blocks.size > 0 -%}
          <ul class="mp-bullets">
            {%- for block in bullet_blocks -%}
              <li class="mp-bullet" {{ block.shopify_attributes }}>
                <span class="mp-bullet__check"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
                {{ block.settings.text }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if bundle_blocks.size > 0 -%}
          <div class="mp-bundle-section">
            <p class="mp-bundle-heading">{{ section.settings.bundle_heading }}</p>
            <div class="mp-bundle-cards" role="radiogroup" aria-label="Seleccionar pack">
              {%- for block in bundle_blocks -%}
                {%- assign b_price   = block.settings.price -%}
                {%- assign b_compare = block.settings.compare_price -%}
                {%- assign b_title   = block.settings.title -%}
                {%- assign b_badge   = block.settings.badge_text -%}
                {%- assign b_unit    = block.settings.unit_label -%}
                {%- assign b_saving  = block.settings.saving_text -%}
                <button
                  type="button"
                  class="mp-bundle-card{% if forloop.first %} active{% endif %}"
                  data-price-display="{{ b_price }}"
                  data-qty="{{ block.settings.qty }}"
                  data-variant-id="{{ cv.id }}"
                  data-bundle-index="{{ forloop.index }}"
                  role="radio"
                  aria-checked="{% if forloop.first %}true{% else %}false{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {%- if b_badge != blank -%}<span class="mp-bundle-card__badge">{{ b_badge }}</span>{%- endif -%}
                  <span class="mp-bundle-card__radio"><span class="mp-bundle-card__radio-dot"></span></span>
                  <span class="mp-bundle-card__info">
                    <span class="mp-bundle-card__title">{{ b_title }}</span>
                    {%- if b_unit != blank -%}<span class="mp-bundle-card__unit">{{ b_unit }}</span>{%- endif -%}
                  </span>
                  <span class="mp-bundle-card__price-wrap">
                    <span class="mp-bundle-card__price">{{ b_price }}</span>
                    {%- if b_compare != blank -%}<span class="mp-bundle-card__compare">{{ b_compare }}</span>{%- endif -%}
                    {%- if b_saving != blank -%}<span class="mp-bundle-card__saving">{{ b_saving }}</span>{%- endif -%}
                  </span>
                </button>
              {%- endfor -%}
            </div>
          </div>

          {%- if section.settings.gift_name != blank -%}
            <div class="mp-gift" id="mp-gift" aria-live="polite" aria-label="Regalo incluido">
              <span class="mp-gift__icon">🎁</span>
              <div class="mp-gift__body">
                <p class="mp-gift__tag">✔ Regalo incluido</p>
                <p class="mp-gift__name">{{ section.settings.gift_name }}</p>
                <p class="mp-gift__sub">Se aplica automáticamente en el checkout</p>
              </div>
              <div class="mp-gift__price">
                <span class="mp-gift__free">GRATIS</span>
                {%- if section.settings.gift_value != blank -%}
                  <span class="mp-gift__was">{{ section.settings.gift_value }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endif -%}

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div>
              <p class="mp-variant-label">{{ option.name }}: <span id="mp-opt-{{ forloop.index }}">{{ option.selected_value }}</span></p>
              <div class="mp-variant-options">
                {%- for value in option.values -%}
                  <button type="button" class="mp-variant-btn{% if value == option.selected_value %} active{% endif %}" data-opt="{{ forloop.parentloop.index0 }}" data-val="{{ value }}">{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}

        <div>
          {%- if bundle_blocks.size == 0 -%}<p class="mp-qty-label">Cantidad</p>{%- endif -%}
          <div class="mp-atc-row" id="mp-atc-anchor">
            {%- if bundle_blocks.size == 0 -%}
              <div class="mp-qty">
                <button type="button" class="mp-qty-btn" id="mp-dec">−</button>
                <input type="number" class="mp-qty-input" id="mp-qty" value="1" min="1" max="99">
                <button type="button" class="mp-qty-btn" id="mp-inc">+</button>
              </div>
            {%- endif -%}
            <button type="button" class="mp-atc-btn" id="mp-atc" data-variant-id="{{ cv.id }}" data-qty="1" {% unless cv.available %}disabled{% endunless %}>
              {%- if cv.available -%}Agregar al carrito{%- else -%}Agotado{%- endif -%}
            </button>
          </div>
        </div>

        {%- if cv.available -%}
          <div class="mp-fomo" id="mp-fomo" aria-live="polite">
            <span class="mp-fomo__dot"></span>
            <span><strong id="mp-fomo-num">--</strong> personas están mirando este producto ahora</span>
          </div>
        {%- endif -%}

        <div class="mp-trust-mini">
          <div class="mp-trust-mini__item"><span class="mp-trust-mini__icon">🛡️</span><span class="mp-trust-mini__label">Garantía 30 días</span><span class="mp-trust-mini__sub">Reembolso total</span></div>
          <div class="mp-trust-mini__item"><span class="mp-trust-mini__icon">🚚</span><span class="mp-trust-mini__label">Envío 3–5 días</span><span class="mp-trust-mini__sub">Gratis desde 50€</span></div>
          <div class="mp-trust-mini__item"><span class="mp-trust-mini__icon">🔒</span><span class="mp-trust-mini__label">Pago seguro</span><span class="mp-trust-mini__sub">Visa, PayPal, Bizum</span></div>
        </div>

        <!-- LOGOS DE PAGO SVG -->
        <div class="mp-payments" aria-label="Métodos de pago aceptados">
          <span class="mp-pay-logo" title="Visa">
            <svg viewBox="0 0 50 16" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Visa">
              <rect width="50" height="16" rx="2" fill="#fff"/><text x="5" y="12" font-family="Arial,sans-serif" font-size="11" font-weight="900" fill="#1A1F71" letter-spacing="-0.5">VISA</text>
            </svg>
          </span>
          <span class="mp-pay-logo" title="Mastercard">
            <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mastercard">
              <rect width="38" height="24" rx="3" fill="#fff"/><circle cx="14" cy="12" r="7" fill="#EB001B"/><circle cx="24" cy="12" r="7" fill="#F79E1B"/><path d="M19 6.8a7 7 0 0 1 0 10.4A7 7 0 0 1 19 6.8z" fill="#FF5F00"/>
            </svg>
          </span>
          <span class="mp-pay-logo" title="PayPal">
            <svg viewBox="0 0 60 20" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="PayPal">
              <rect width="60" height="20" rx="3" fill="#fff"/><text x="6" y="14" font-family="Arial,sans-serif" font-size="10" font-weight="800" fill="#003087">Pay</text><text x="26" y="14" font-family="Arial,sans-serif" font-size="10" font-weight="800" fill="#009cde">Pal</text>
            </svg>
          </span>
          <span class="mp-pay-logo" title="Bizum">
            <svg viewBox="0 0 56 20" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Bizum">
              <rect width="56" height="20" rx="3" fill="#fff"/><text x="5" y="14" font-family="Arial,sans-serif" font-size="10" font-weight="800" fill="#00B259">Bizum</text>
            </svg>
          </span>
          <span class="mp-pay-logo" title="Shop Pay">
            <svg viewBox="0 0 66 20" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Shop Pay">
              <rect width="66" height="20" rx="3" fill="#5A31F4"/><text x="6" y="14" font-family="Arial,sans-serif" font-size="9" font-weight="700" fill="#fff">Shop Pay</text>
            </svg>
          </span>
        </div>

        <div>
          {%- if product.description != blank -%}
            <div class="mp-accordion">
              <button type="button" class="mp-accordion-btn" aria-expanded="false">
                Detalles del producto
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="mp-accordion-content">
                <ul class="mp-details-list">
                  <li>Capacidad: <strong>285 ml</strong> — suficiente para un paseo largo</li>
                  <li>Material: <strong>Acero inoxidable 304</strong> grado alimentario, sin BPA ni olores</li>
                  <li>Cuenco de <strong>silicona alimentaria</strong> plegable, fácil de limpiar</li>
                  <li>Cierre hermético de silicona — <strong>no gotea</strong> al revés en la mochila</li>
                  <li>Gancho de acero integrado para correa o mosquetón</li>
                  <li>Peso: <strong>~180 g</strong> sin agua. Cabe en bolsillos estándar de mochila</li>
                  <li>Lavavajillas: ✓ Ciclo corto. Cuenco desmontable para limpieza en profundidad</li>
                </ul>
              </div>
            </div>
          {%- endif -%}
          <div class="mp-accordion"><button type="button" class="mp-accordion-btn" aria-expanded="false">Información de entrega <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button><div class="mp-accordion-content">{{ section.settings.shipping_text }}</div></div>
          <div class="mp-accordion"><button type="button" class="mp-accordion-btn" aria-expanded="false">Prueba de 30 días <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button><div class="mp-accordion-content">{{ section.settings.returns_text }}</div></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── PUNTO 1: Benefits band + lifestyle collage debajo ── -->
  <div class="mp-benefits">
    <div class="mp-benefit"><div class="mp-benefit__icon">💧</div><p class="mp-benefit__title">Hidratación instantánea</p><p class="mp-benefit__sub">Lista en segundos</p></div>
    <div class="mp-benefit"><div class="mp-benefit__icon">🎒</div><p class="mp-benefit__title">Siempre contigo</p><p class="mp-benefit__sub">Cabe en cualquier bolsillo</p></div>
    <div class="mp-benefit"><div class="mp-benefit__icon">🛡️</div><p class="mp-benefit__title">Acero 304</p><p class="mp-benefit__sub">Sin olores, sin BPA</p></div>
    <div class="mp-benefit"><div class="mp-benefit__icon">↩️</div><p class="mp-benefit__title">30 días de prueba</p><p class="mp-benefit__sub">Devolución gratis</p></div>
  </div>

  <!-- Lifestyle collage full-width + imagen CANVOY estilo 1 -->
  <div class="mp-lifestyle-strip">
    <img
      src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/Transform_this_product_lifestyle_collage_202606111326.jpg?v=1781177623"
      alt="CANVOY en acción — collage lifestyle"
      class="mp-lifestyle-strip__img"
      loading="lazy"
      width="800"
      height="600"
    >
    <img
      src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/Transform_this_image_to_CANVOY_202606111331.jpg?v=1781177621"
      alt="CANVOY estilo — botella con perro"
      class="mp-lifestyle-strip__img"
      loading="lazy"
      width="800"
      height="600"
    >
  </div>

  <!-- ── PUNTO 2: Stats con imagen lateral ── -->
  <div class="mp-stats">
    <div class="wrap">
      <div class="mp-stats__inner">
        <div class="mp-stats__grid">
          <div><p class="mp-stat__value">4.9★</p><p class="mp-stat__label">Valoración media</p></div>
          <div><p class="mp-stat__value">+500</p><p class="mp-stat__label">Familias CANVOY</p></div>
          <div><p class="mp-stat__value">+1.200</p><p class="mp-stat__label">Rutas completadas</p></div>
        </div>
        <div class="mp-stats__img-wrap">
          <img
            src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/Transform_this_image_to_CANVOY_202606111333.jpg?v=1781177620"
            alt="CANVOY — perro hidratándose en ruta"
            loading="lazy"
            width="600"
            height="450"
          >
        </div>
      </div>
    </div>
  </div>

  <div class="mp-testimonials"><div class="wrap">
    <p class="mp-section-tag">Clientes reales</p>
    <h2 class="mp-section-heading">Lo que dicen nuestros paseadores</h2>
    <p class="mp-section-sub">Dueños activos que ya lo usan en sus rutas diarias.</p>
    <div class="mp-testimonials-grid">
      <div class="mp-testimonial"><div class="mp-testimonial__stars">★★★★★</div><p class="mp-testimonial__text">&ldquo;Salimos todos los fines de semana a la sierra. Desde que tengo la CANVOY no he vuelto a improvisar. Mi golden se la terminó en 2 minutos.&rdquo;</p><div class="mp-testimonial__author"><div class="mp-testimonial__avatar">ML</div><div><p class="mp-testimonial__name">María L. &mdash; Golden Retriever</p><p class="mp-testimonial__meta">Madrid &middot; <span class="mp-verified">✓ Compra verificada</span></p></div></div></div>
      <div class="mp-testimonial"><div class="mp-testimonial__stars">★★★★★</div><p class="mp-testimonial__text">&ldquo;Pensé que sería otro gadget más. Llevo 3 meses usándola a diario y el cierre no gotea ni dentro de la mochila.&rdquo;</p><div class="mp-testimonial__author"><div class="mp-testimonial__avatar">CR</div><div><p class="mp-testimonial__name">Carlos R. &mdash; Labrador</p><p class="mp-testimonial__meta">Barcelona &middot; <span class="mp-verified">✓ Compra verificada</span></p></div></div></div>
      <div class="mp-testimonial"><div class="mp-testimonial__stars">★★★★★</div><p class="mp-testimonial__text">&ldquo;La compré por el diseño y me quedé por lo práctica. Mi border collie la reconoce cuando la saco del bolsillo.&rdquo;</p><div class="mp-testimonial__author"><div class="mp-testimonial__avatar">AM</div><div><p class="mp-testimonial__name">Ana M. &mdash; Border Collie</p><p class="mp-testimonial__meta">Valencia &middot; <span class="mp-verified">✓ Compra verificada</span></p></div></div></div>
      <div class="mp-testimonial"><div class="mp-testimonial__stars">★★★★★</div><p class="mp-testimonial__text">&ldquo;No gotea en la mochila. Eso para mí lo cambia todo. La llevo en el bolsillo lateral y ni la noto.&rdquo;</p><div class="mp-testimonial__author"><div class="mp-testimonial__avatar">SL</div><div><p class="mp-testimonial__name">Sofía L. &mdash; Husky</p><p class="mp-testimonial__meta">Bilbao &middot; <span class="mp-verified">✓ Compra verificada</span></p></div></div></div>
    </div>
  </div></div>

  <!-- ── PUNTO 3: Garantía — imagen real en lugar del badge genérico ── -->
  <div class="mp-guarantee"><div class="wrap"><div class="mp-guarantee__inner">
    <div>
      <span class="mp-guarantee__badge">🛡️ Garantía total</span>
      <h2 class="mp-guarantee__heading">30 días o te devolvemos el dinero</h2>
      <p class="mp-guarantee__sub">Sin formularios. Sin llamadas. Sin excusas. Si no estás satisfecho, te reembolsamos en menos de 48 horas.</p>
      <div class="mp-guarantee__steps">
        <div class="mp-guarantee__step"><div class="mp-guarantee__step-num">1</div><div><p class="mp-guarantee__step-title">Escríbenos</p><p class="mp-guarantee__step-text">Por email o WhatsApp. Sin formularios complicados.</p></div></div>
        <div class="mp-guarantee__step"><div class="mp-guarantee__step-num">2</div><div><p class="mp-guarantee__step-title">Devuelve el producto</p><p class="mp-guarantee__step-text">Te enviamos la etiqueta prepagada. Sin coste para ti.</p></div></div>
        <div class="mp-guarantee__step"><div class="mp-guarantee__step-num">3</div><div><p class="mp-guarantee__step-title">Reembolso en 48h</p><p class="mp-guarantee__step-text">Directo a tu tarjeta o PayPal. Sin esperas.</p></div></div>
      </div>
    </div>
    <div class="mp-guarantee__visual">
      <img
        src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/generated-image_4.png?v=1781177624"
        alt="CANVOY — garantía de satisfacción"
        loading="lazy"
        width="600"
        height="450"
      >
    </div>
  </div></div></div>

  <div class="mp-faq" id="mp-faq"><div class="wrap">
    <p class="mp-section-tag">Dudas frecuentes</p>
    <h2 class="mp-section-heading">Preguntas frecuentes</h2>
    <div class="mp-faq__list">
      <div class="mp-faq__item"><button type="button" class="mp-faq__q" aria-expanded="false">¿Cuánta agua cabe? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button><div class="mp-faq__a">285ml — suficiente para razas pequeñas y medianas en un paseo largo. Para razas grandes recomendamos rellenar cada 45-60 minutos.</div></div>
      <div class="mp-faq__item"><button type="button" class="mp-faq__q" aria-expanded="false">¿Realmente no gotea? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button><div class="mp-faq__a">El sello de silicona garantiza cierre hermético. Puedes meterla al revés en tu mochila. Si hay cualquier problema en 30 días, te enviamos una nueva sin coste.</div></div>
      <div class="mp-faq__item"><button type="button" class="mp-faq__q" aria-expanded="false">¿Cuánto tarda en llegar? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button><div class="mp-faq__a">3 a 5 días hábiles con seguimiento en tiempo real. También enviamos a Portugal, Francia e Italia.</div></div>
      <div class="mp-faq__item"><button type="button" class="mp-faq__q" aria-expanded="false">¿Es segura para mi perro? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button><div class="mp-faq__a">100%. Acero inoxidable 304 grado alimentario, sin BPA. Cuenco de silicona alimentaria — el mismo material que los chupetes de bebé.</div></div>
      <div class="mp-faq__item"><button type="button" class="mp-faq__q" aria-expanded="false">¿Cómo se limpia? <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg></button><div class="mp-faq__a">10 segundos bajo el grifo con jabón. También apta para lavavajillas en ciclo corto. El cuenco se desmonta para limpieza en profundidad.</div></div>
    </div>
  </div></div>

  <div class="mp-cta-banner"><div class="wrap">
    <div class="mp-cta-banner__icon">🐾</div>
    <h2 class="mp-cta-banner__heading">¿Listo para la próxima ruta?</h2>
    <p class="mp-cta-banner__text">Únete a más de 500 dueños activos que ya salen con CANVOY.</p>
    <button type="button" class="mp-cta-banner__btn" id="mp-cta-atc">Añadir al carrito</button>
    <p class="mp-cta-banner__trust">✓ Garantía 30 días &nbsp;·&nbsp; ✓ Envío 3–5 días &nbsp;·&nbsp; ✓ Devolución gratis</p>
  </div></div>

  <!-- Anchor para Judge.me — el widget irá aquí cuando instales la app -->
  <div id="mp-reviews"></div>

</div>

<div class="mp-sticky" id="mp-sticky">
  <div class="mp-sticky__inner">
    <div class="mp-sticky__info">
      {%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 80 }}" alt="" class="mp-sticky__img" width="48" height="48">{%- endif -%}
      <div>
        <p class="mp-sticky__title">{{ product.title | truncate: 30 }}</p>
        <p class="mp-sticky__price" id="mp-sticky-price">{{ cv.price | money }}</p>
      </div>
    </div>
    <button type="button" class="mp-sticky__btn" id="mp-sticky-atc" data-variant-id="{{ cv.id }}" data-qty="1" {% unless cv.available %}disabled{% endunless %}>Agregar al carrito</button>
  </div>
</div>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "subtitle",           "label": "Subtítulo",              "default": "La botella con cuenco integrado para hidratar a tu perro en cualquier ruta." },
    { "type": "text",     "id": "review_count_text",  "label": "Texto de reseñas",       "default": "4.9 · 127 reseñas" },
    { "type": "textarea", "id": "shipping_text",       "label": "Texto de envío",         "default": "Envío gratis desde 50€ · 3-5 días hábiles" },
    { "type": "textarea", "id": "returns_text",        "label": "Texto de devoluciones",  "default": "30 días de prueba sin riesgo. Devuelve sin preguntas." },
    { "type": "text",     "id": "bundle_heading",      "label": "Título selector packs",  "default": "ELIGE TU PACK — CUANTO MÁS LLEVAS, MÁS AHORRAS" },
    { "type": "text",     "id": "gift_name",           "label": "Nombre del regalo",      "default": "" },
    { "type": "text",     "id": "gift_value",          "label": "Valor original del regalo (ej: 9,99€)", "default": "" }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet point",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "✓ Beneficio clave del producto" }
      ]
    },
    {
      "type": "bundle",
      "name": "Pack / Bundle",
      "settings": [
        { "type": "text",   "id": "title",         "label": "Título del pack",         "default": "Pack 1 unidad" },
        { "type": "text",   "id": "unit_label",    "label": "Descripción secundaria",  "default": "1 botella CANVOY Pro" },
        { "type": "text",   "id": "price",         "label": "Precio mostrado",         "default": "24,99€" },
        { "type": "text",   "id": "compare_price", "label": "Precio tachado",          "default": "" },
        { "type": "text",   "id": "saving_text",   "label": "Texto ahorro",            "default": "" },
        { "type": "text",   "id": "badge_text",    "label": "Badge (ej: MÁS POPULAR)", "default": "" },
        { "type": "number", "id": "qty",           "label": "Cantidad al añadir",      "default": 1 }
      ]
    }
  ],
  "presets": [{ "name": "Main Product" }]
}
{% endschema %}
