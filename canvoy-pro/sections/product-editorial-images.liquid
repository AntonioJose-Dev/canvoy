{% comment %}
  product-editorial-images.liquid
  Sección de imágenes editoriales estilo DTC — mobile-first
  Orden probado de conversión:
  1. Imagen emocional (dolor/problema)
  2. Lifestyle collage
  3-4. Imágenes de estilo/producto CANVOY
{% endcomment %}

<section class="product-editorial" id="product-editorial">
  <div class="editorial-inner">

    {%- comment -%} IMAGEN 1 — Emocional full-width {%- endcomment -%}
    <div class="editorial-block editorial-block--full">
      <img
        src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/generated-image_4.png?v=1781177624"
        alt="Tu perro sufre sed silenciosa en cada paseo — CANVOY bebedero portátil"
        width="800"
        height="1400"
        loading="lazy"
        decoding="async"
        class="editorial-img editorial-img--portrait"
      >
    </div>

    {%- comment -%} IMAGEN 2 — Collage lifestyle {%- endcomment -%}
    <div class="editorial-block editorial-block--full">
      <img
        src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/Transform_this_product_lifestyle_collage_202606111326.jpg?v=1781177623"
        alt="CANVOY botella portátil para perros — ligero, portátil, práctico, con estilo"
        width="1200"
        height="900"
        loading="lazy"
        decoding="async"
        class="editorial-img editorial-img--landscape"
      >
    </div>

    {%- comment -%} IMAGEN 3 + 4 — Dos columnas en desktop, apiladas en mobile {%- endcomment -%}
    <div class="editorial-block editorial-block--duo">
      <div class="editorial-duo-item">
        <img
          src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/Transform_this_image_to_CANVOY_202606111331.jpg?v=1781177621"
          alt="CANVOY bebedero portátil acero inoxidable — diseño premium para perros"
          width="600"
          height="750"
          loading="lazy"
          decoding="async"
          class="editorial-img editorial-img--square"
        >
      </div>
      <div class="editorial-duo-item">
        <img
          src="https://cdn.shopify.com/s/files/1/0996/8730/1494/files/Transform_this_image_to_CANVOY_202606111333.jpg?v=1781177620"
          alt="CANVOY botella con cuenco plegable para perros — hidratación en cada paseo"
          width="600"
          height="750"
          loading="lazy"
          decoding="async"
          class="editorial-img editorial-img--square"
        >
      </div>
    </div>

  </div>
</section>

<style>
  /* ── BASE MOBILE-FIRST ── */
  .product-editorial {
    width: 100%;
    background: #ffffff;
    padding: 0;
    overflow: hidden;
  }

  .editorial-inner {
    display: flex;
    flex-direction: column;
    gap: 3px;
    max-width: 100%;
  }

  .editorial-block {
    width: 100%;
    overflow: hidden;
    line-height: 0; /* elimina gap inferior por inline img */
  }

  .editorial-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* PORTRAIT — imagen tall en móvil: aspect-ratio fijo, nada de max-height */
  .editorial-img--portrait {
    aspect-ratio: 3 / 4;
    object-position: center top;
  }

  /* LANDSCAPE — 4:3 en móvil */
  .editorial-img--landscape {
    aspect-ratio: 4 / 3;
  }

  /* SQUARE — 4:5 en móvil */
  .editorial-img--square {
    aspect-ratio: 4 / 5;
  }

  /* DUO — apiladas en móvil */
  .editorial-block--duo {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3px;
  }

  .editorial-duo-item {
    overflow: hidden;
    line-height: 0;
  }

  /* hover solo en dispositivos con puntero */
  @media (hover: hover) and (pointer: fine) {
    .editorial-img {
      transition: transform 0.4s ease;
    }
    .editorial-img:hover {
      transform: scale(1.02);
    }
  }

  /* ── TABLET 600px+ ── */
  @media (min-width: 600px) {
    .editorial-inner {
      gap: 4px;
    }

    .editorial-img--portrait {
      aspect-ratio: 2 / 3;
    }

    .editorial-block--duo {
      grid-template-columns: 1fr 1fr;
      gap: 4px;
    }
  }

  /* ── DESKTOP 1024px+ ── */
  @media (min-width: 1024px) {
    .editorial-inner {
      max-width: 900px;
      margin: 0 auto;
      gap: 6px;
    }

    .editorial-img--portrait {
      aspect-ratio: 3 / 4;
    }

    .editorial-img--landscape {
      aspect-ratio: 16 / 9;
    }

    .editorial-block--duo {
      gap: 6px;
    }
  }
</style>

{% schema %}
{
  "name": "Imágenes Editoriales",
  "tag": "section",
  "class": "section-product-editorial",
  "settings": [],
  "presets": [
    {
      "name": "Imágenes Editoriales"
    }
  ]
}
{% endschema %}
