{%- if section.settings.show -%}
<section class="product-cta-banner product-cta-banner--text-only">
  <div class="wrap product-cta-banner__inner">
    {%- if section.settings.icon != blank -%}
      <span class="product-cta-banner__icon" aria-hidden="true">{{ section.settings.icon }}</span>
    {%- endif -%}
    <h2>{{ section.settings.heading }}</h2>
    {%- if section.settings.text != blank -%}<p>{{ section.settings.text }}</p>{%- endif -%}
    <button type="button" class="btn btn--primary btn--lg product-cta-banner__btn" id="scroll-to-atc">
      {{ section.settings.btn_text }}
    </button>
  </div>
</section>
{%- endif -%}
{% schema %}
{
  "name": "CTA final producto",
  "settings": [
    {"type":"checkbox","id":"show","label":"Mostrar sección","default":false,"info":"Desactivado por defecto: el producto ya aparece arriba. Activa solo si quieres un cierre de texto sin repetir foto."},
    {"type":"text","id":"icon","label":"Icono","default":"🐾"},
    {"type":"text","id":"heading","label":"Titular","default":"¿Listo para la próxima ruta?"},
    {"type":"textarea","id":"text","label":"Texto","default":"Vuelve arriba y añádelo al carrito en un clic."},
    {"type":"text","id":"btn_text","label":"Texto botón","default":"Ir al botón de compra ↑"}
  ],
  "presets": [{"name": "CTA final producto"}]
}
{% endschema %}
