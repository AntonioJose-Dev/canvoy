<section class="section collections-section">
  <div class="collections-section__paws" aria-hidden="true">
    {%- for i in (1..10) -%}
      <span class="collections-section__paw collections-section__paw--{{ i }}">{%- render 'paw-print' -%}</span>
    {%- endfor -%}
  </div>
  <div class="wrap">
    <div class="section-head">
      <p class="section-tag collections-section__tag">
        <span class="collections-section__tag-paw">{%- render 'paw-print' -%}</span>
        {{ section.settings.tag }}
      </p>
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="collections-grid">
      {%- assign auto_index = 0 -%}
      {%- for i in (1..3) -%}
        {%- assign col_setting = 'col' | append: i | append: '_handle' -%}
        {%- assign col_img_setting = 'col' | append: i | append: '_image' -%}
        {%- assign col_label_setting = 'col' | append: i | append: '_label' -%}
        {%- assign the_col = section.settings[col_setting] -%}
        {%- if the_col == blank -%}
          {%- for collection in collections -%}
            {%- if collection.all_products_count > 0 and collection.handle != 'frontpage' -%}
              {%- assign auto_index = auto_index | plus: 1 -%}
              {%- if auto_index == i -%}
                {%- assign the_col = collection -%}
                {%- break -%}
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
        {%- if the_col == blank -%}{%- continue -%}{%- endif -%}
        {%- assign card_img = section.settings[col_img_setting] -%}
        {%- if card_img == blank -%}
          {%- assign card_img = the_col.image -%}
        {%- endif -%}
        {%- if card_img == blank and the_col.products.first.featured_image != blank -%}
          {%- assign card_img = the_col.products.first.featured_image -%}
        {%- endif -%}
        {%- assign card_label = section.settings[col_label_setting] | default: the_col.title -%}
        <a href="{{ the_col.url }}" class="collection-card">
          <span class="collection-card__paw collection-card__paw--tl">{%- render 'paw-print' -%}</span>
          <span class="collection-card__paw collection-card__paw--br">{%- render 'paw-print' -%}</span>
          {%- if card_img != blank -%}
            <img src="{{ card_img | image_url: width: 800 }}" alt="{{ card_label | escape }}" class="collection-card__img" loading="lazy" width="800" height="1067">
          {%- else -%}
            <div class="collection-card__img collection-card__placeholder"></div>
          {%- endif -%}
          <div class="collection-card__overlay"></div>
          <div class="collection-card__content">
            <h3 class="collection-card__name">{{ card_label }}</h3>
            <span class="collection-card__cta">
              <span class="collection-card__cta-paw">{%- render 'paw-print' -%}</span>
              Ver colección →
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Colecciones destacadas",
  "settings": [
    {"type":"text","id":"tag","label":"Etiqueta","default":"Nuestras categorías"},
    {"type":"text","id":"heading","label":"Titular","default":"Equipado para cada aventura"},
    {"type":"textarea","id":"subheading","label":"Subtítulo","default":"Desde el paseo diario hasta la ruta de montaña."},
    {"type":"collection","id":"col1_handle","label":"Colección 1 (vacío = auto)"},
    {"type":"image_picker","id":"col1_image","label":"Imagen 1 (opcional)"},
    {"type":"text","id":"col1_label","label":"Nombre 1 (opcional)"},
    {"type":"collection","id":"col2_handle","label":"Colección 2 (vacío = auto)"},
    {"type":"image_picker","id":"col2_image","label":"Imagen 2 (opcional)"},
    {"type":"text","id":"col2_label","label":"Nombre 2 (opcional)"},
    {"type":"collection","id":"col3_handle","label":"Colección 3 (vacío = auto)"},
    {"type":"image_picker","id":"col3_image","label":"Imagen 3 (opcional)"},
    {"type":"text","id":"col3_label","label":"Nombre 3 (opcional)"}
  ],
  "presets":[{"name":"Colecciones destacadas"}]
}
{% endschema %}
