<section class="section product-faq-section">
  <div class="wrap product-faq-section__inner">
    <div class="section-head section-head--centered">
      <p class="section-tag">{{ section.settings.tag }}</p>
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="product-faq-list">
      {%- for block in section.blocks -%}
        <div class="product-faq-list__item" {{ block.shopify_attributes }}>
          <button type="button" class="accordion-btn product-faq-list__btn" aria-expanded="false">
            {{ block.settings.question }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="accordion-content product-faq-list__answer">{{ block.settings.answer }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{%- if section.blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
      {
        "@type": "Question",
        "name": {{ block.settings.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ block.settings.answer | json }}
        }
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ producto",
  "settings": [
    {"type":"text","id":"tag","label":"Etiqueta","default":"Dudas frecuentes"},
    {"type":"text","id":"heading","label":"Titular","default":"Preguntas frecuentes"}
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        {"type":"text","id":"question","label":"Pregunta","default":"¿Cómo se utiliza durante los paseos?"},
        {"type":"textarea","id":"answer","label":"Respuesta","default":"Despliega el tazón, añade agua o comida y listo. En pocos segundos tu perro puede beber."}
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ producto",
      "blocks": [
        {"type":"faq","settings":{"question":"¿Cuánta agua cabe?","answer":"285ml — suficiente para razas pequeñas y medianas en un paseo o ruta de varias horas."}},
        {"type":"faq","settings":{"question":"¿Realmente no gotea?","answer":"El sello de silicona garantiza cierre hermético. Si hay cualquier problema en los primeros 30 días, te lo resolvemos sin coste."}},
        {"type":"faq","settings":{"question":"¿Cuánto tarda en llegar a España?","answer":"3 a 5 días hábiles con número de seguimiento en tiempo real desde el momento del envío."}},
        {"type":"faq","settings":{"question":"¿Es segura para mi perro?","answer":"100%. Acero inoxidable 304 grado alimentario, sin BPA. El cuenco es silicona alimentaria — el mismo material que los chupetes de bebé."}},
        {"type":"faq","settings":{"question":"¿Cómo se limpia?","answer":"10 segundos bajo el grifo con jabón. También apta para lavavajillas en ciclo corto."}}
      ]
    }
  ]
}
{% endschema %}
