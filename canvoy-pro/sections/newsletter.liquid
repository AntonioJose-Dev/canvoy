<section class="section newsletter-section">
  <div class="wrap">
    <div class="newsletter-block">
      <div class="newsletter-block__content">
        {%- if section.settings.tag != blank -%}
          <p class="section-tag">{{ section.settings.tag }}</p>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <p class="newsletter-block__sub">{{ section.settings.subheading }}</p>
        {%- if section.settings.show_incentive -%}
          <ul class="newsletter-incentives">
            {%- if section.settings.incentive_1 != blank -%}<li>{{ section.settings.incentive_1 }}</li>{%- endif -%}
            {%- if section.settings.incentive_2 != blank -%}<li>{{ section.settings.incentive_2 }}</li>{%- endif -%}
            {%- if section.settings.incentive_3 != blank -%}<li>{{ section.settings.incentive_3 }}</li>{%- endif -%}
          </ul>
        {%- endif -%}
      </div>
      {%- form 'customer', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form__row">
          <input
            type="email"
            name="contact[email]"
            class="newsletter-form__input"
            placeholder="{{ section.settings.placeholder }}"
            required
            aria-label="Email"
          >
          <button type="submit" class="btn btn--primary">{{ section.settings.btn_text }}</button>
        </div>
        <p class="newsletter-form__disclaimer">{{ section.settings.disclaimer }}</p>
        {%- if form.posted_successfully? -%}
          <p class="newsletter-success">✓ ¡Dentro! Revisa tu correo — el cupón está de camino. 🐾</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .newsletter-incentives {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
  }
  .newsletter-incentives li {
    font-size: 0.85rem;
    color: #6b7280;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .newsletter-incentives li::before {
    content: '✓';
    color: #FF5A1F;
    font-weight: 700;
  }
  .newsletter-form__disclaimer {
    font-size: 0.75rem;
    color: #9ca3af;
    margin: 8px 0 0;
  }
  .newsletter-success {
    color: #16a34a;
    font-size: 0.9rem;
    margin-top: 10px;
    font-weight: 600;
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {"type":"text","id":"tag","label":"Etiqueta","default":"Únete a la manada"},
    {"type":"text","id":"heading","label":"Titular","default":"10% de descuento en tu primer pedido"},
    {"type":"text","id":"subheading","label":"Subtítulo","default":"Más consejos de aventura, novedades y ofertas exclusivas. Sin spam."},
    {"type":"header","content":"Incentivos visibles"},
    {"type":"checkbox","id":"show_incentive","label":"Mostrar lista de incentivos","default":true},
    {"type":"text","id":"incentive_1","label":"Incentivo 1","default":"10% de descuento inmediato"},
    {"type":"text","id":"incentive_2","label":"Incentivo 2","default":"Acceso anticipado a nuevos productos"},
    {"type":"text","id":"incentive_3","label":"Incentivo 3","default":"Rutas y consejos para dueños activos"},
    {"type":"header","content":"Formulario"},
    {"type":"text","id":"placeholder","label":"Placeholder","default":"Tu correo electrónico"},
    {"type":"text","id":"btn_text","label":"Texto botón","default":"Quiero el 10%"},
    {"type":"text","id":"disclaimer","label":"Disclaimer bajo el input","default":"Sin spam. Te puedes dar de baja cuando quieras."}
  ],
  "presets":[{"name":"Newsletter"}]
}
{% endschema %}
