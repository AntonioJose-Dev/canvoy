<style>
  .product-guarantee {
    background: {{ section.settings.bg_color }};
    padding: 56px 0;
  }
  .product-guarantee__inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .product-guarantee__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: {{ section.settings.badge_bg }};
    font-size: 2.4rem;
    margin-bottom: 20px;
  }
  .product-guarantee__heading {
    font-size: 1.6rem;
    font-weight: 800;
    margin: 0 0 8px;
  }
  .product-guarantee__subheading {
    color: #6b7280;
    margin: 0 0 36px;
    font-size: 1rem;
  }
  .product-guarantee__steps {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .product-guarantee__step {
    flex: 1;
    min-width: 180px;
    max-width: 220px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 20px 16px;
    text-align: center;
  }
  .product-guarantee__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: {{ section.settings.badge_bg }};
    color: #fff;
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 10px;
  }
  .product-guarantee__step-title {
    font-weight: 700;
    font-size: 0.9rem;
    margin-bottom: 4px;
  }
  .product-guarantee__step-text {
    font-size: 0.82rem;
    color: #6b7280;
    margin: 0;
  }
  .product-guarantee__cta {
    font-size: 0.88rem;
    color: #6b7280;
  }
  .product-guarantee__cta strong {
    color: #111;
  }
  @media (max-width: 600px) {
    .product-guarantee__steps { flex-direction: column; align-items: center; }
    .product-guarantee__step { min-width: 0; width: 100%; max-width: 320px; }
    .product-guarantee__heading { font-size: 1.3rem; }
  }
</style>

{%- if section.settings.show -%}
<section class="product-guarantee" aria-label="Garantía">
  <div class="wrap product-guarantee__inner">

    <div class="product-guarantee__badge" aria-hidden="true">{{ section.settings.icon }}</div>
    <h2 class="product-guarantee__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.subheading != blank -%}
      <p class="product-guarantee__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="product-guarantee__steps">
      {%- for i in (1..3) -%}
        {%- assign step_title_key = 'step' | append: i | append: '_title' -%}
        {%- assign step_text_key  = 'step' | append: i | append: '_text' -%}
        {%- if section.settings[step_title_key] != blank -%}
          <div class="product-guarantee__step">
            <div class="product-guarantee__step-num" aria-hidden="true">0{{ i }}</div>
            <p class="product-guarantee__step-title">{{ section.settings[step_title_key] }}</p>
            <p class="product-guarantee__step-text">{{ section.settings[step_text_key] }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_text != blank -%}
      <p class="product-guarantee__cta">{{ section.settings.cta_text }}</p>
    {%- endif -%}

  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Garantía",
  "tag": "section",
  "settings": [
    {"type":"checkbox","id":"show","label":"Mostrar sección","default":true},
    {"type":"color","id":"bg_color","label":"Color de fondo","default":"#fff7ed"},
    {"type":"color","id":"badge_bg","label":"Color acento (badge + números)","default":"#FF5A1F"},
    {"type":"text","id":"icon","label":"Icono principal","default":"🛡️"},
    {"type":"text","id":"heading","label":"Titular","default":"30 días o te devolvemos el dinero"},
    {"type":"textarea","id":"subheading","label":"Subtítulo","default":"Sin formularios. Sin llamadas. Sin excusas. Si no estás satisfecho, te reembolsamos en menos de 48 horas."},
    {"type":"header","content":"Paso 1"},
    {"type":"text","id":"step1_title","label":"Título paso 1","default":"Escríbenos"},
    {"type":"text","id":"step1_text","label":"Texto paso 1","default":"Por email o WhatsApp. Sin formularios complicados."},
    {"type":"header","content":"Paso 2"},
    {"type":"text","id":"step2_title","label":"Título paso 2","default":"Devuelve el producto"},
    {"type":"text","id":"step2_text","label":"Texto paso 2","default":"Te enviamos la etiqueta prepagada. Sin coste para ti."},
    {"type":"header","content":"Paso 3"},
    {"type":"text","id":"step3_title","label":"Título paso 3","default":"Reembolso en 48h"},
    {"type":"text","id":"step3_text","label":"Texto paso 3","default":"Directo a tu tarjeta o PayPal. Sin esperas."},
    {"type":"header","content":"Texto de cierre"},
    {"type":"text","id":"cta_text","label":"Línea de confianza final","default":"🔒 Pago seguro  ·  🚚 Envío 3–5 días  📦 Seguimiento real"}
  ],
  "presets": [{"name": "Garantía"}]
}
{% endschema %}
