<section class="section product-testimonials-grid">
  <div class="wrap">
    <div class="section-head section-head--centered">
      <div class="product-testimonials-grid__stars" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      </div>
      <h2>{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    <div class="product-testimonials-grid__items">
      {%- for block in section.blocks -%}
        <blockquote class="product-testimonial-card" {{ block.shopify_attributes }}>
          <div class="product-testimonial-card__stars" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <p class="product-testimonial-card__text">"{{ block.settings.text }}"</p>
          <footer class="product-testimonial-card__author">
            <span class="product-testimonial-card__name">{{ block.settings.name }}</span>
            {%- if block.settings.verified -%}<span class="product-testimonial-card__verified"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Verificado</span>{%- endif -%}
          </footer>
        </blockquote>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Testimonios producto",
  "settings": [
    {"type":"text","id":"heading","label":"Titular","default":"Lo que dicen nuestros paseadores"},
    {"type":"textarea","id":"subheading","label":"Subtítulo","default":"Dueños activos que ya lo usan en sus rutas diarias."}
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        {"type":"textarea","id":"text","label":"Texto","default":"Práctico para paseos diarios. Mi perro bebe sin problemas del tazón de silicona."},
        {"type":"text","id":"name","label":"Nombre","default":"Laura M."},
        {"type":"checkbox","id":"verified","label":"Compra verificada","default":true}
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonios producto",
      "blocks": [
        {"type":"testimonial","settings":{"text":"Práctico para paseos diarios. Mi perro bebe sin problemas del tazón de silicona.","name":"Laura M.","verified":true}},
        {"type":"testimonial","settings":{"text":"Fácil de limpiar y muy ligero. Lo llevo en todos los senderos.","name":"Javi R.","verified":true}},
        {"type":"testimonial","settings":{"text":"Resistente de verdad. Se me cayó varias veces y sigue perfecto.","name":"Elena P.","verified":true}},
        {"type":"testimonial","settings":{"text":"No gotea en la mochila. Eso para mí lo cambia todo.","name":"Sofia L.","verified":true}}
      ]
    }
  ]
}
{% endschema %}
