<div class="customers-page"><div class="wrap"><h1>Crear cuenta</h1>{%- form 'create_customer' -%}<div class="form-group"><label>Nombre</label><input type="text" name="customer[first_name]" class="form-input"></div><div class="form-group"><label>Apellido</label><input type="text" name="customer[last_name]" class="form-input"></div><div class="form-group"><label>Email</label><input type="email" name="customer[email]" class="form-input"></div><div class="form-group"><label>Contraseña</label><input type="password" name="customer[password]" class="form-input"></div><button type="submit" class="btn btn--primary btn--full">Crear cuenta</button>{%- endform -%}</div></div>