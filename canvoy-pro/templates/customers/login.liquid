<div class="customers-page"><div class="wrap"><h1>Iniciar sesión</h1>{%- form 'customer_login' -%}<div class="form-group"><label>Email</label><input type="email" name="customer[email]" class="form-input" autocomplete="email"></div><div class="form-group"><label>Contraseña</label><input type="password" name="customer[password]" class="form-input" autocomplete="current-password"></div><button type="submit" class="btn btn--primary btn--full">Entrar</button>{%- endform -%}<p class="customers-page__link"><a href="/account/register">¿No tienes cuenta? Regístrate</a></p></div></div>