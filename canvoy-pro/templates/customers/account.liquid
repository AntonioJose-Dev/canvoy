<div class="customers-page"><div class="wrap"><h1>Mi cuenta</h1><p>Bienvenido, {{ customer.first_name }}.</p><h2>Mis pedidos</h2>{%- if customer.orders.size > 0 -%}<div class="orders-list">{%- for order in customer.orders -%}<div class="order-row"><span>{{ order.name }}</span><span>{{ order.created_at | date: '%d/%m/%Y' }}</span><span>{{ order.financial_status_label }}</span><span>{{ order.total_price | money }}</span><a href="{{ order.customer_url }}">Ver</a></div>{%- endfor -%}</div>{%- else -%}<p>No tienes pedidos todavía.</p>{%- endif -%}<a href="/account/logout" class="btn btn--outline btn--sm">Cerrar sesión</a></div></div>