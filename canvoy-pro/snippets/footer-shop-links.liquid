{%- if linklists.footer.links.size > 0 -%}
  {%- for link in linklists.footer.links -%}
    <a href="{{ link.url }}" class="footer-col__link">{{ link.title }}</a>
  {%- endfor -%}
{%- else -%}
  {%- for collection in collections -%}
    {%- if collection.all_products_count > 0 and collection.handle != 'frontpage' -%}
      <a href="{{ collection.url }}" class="footer-col__link">{{ collection.title }}</a>
      {%- if forloop.index >= 4 -%}{%- break -%}{%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  <a href="{{ routes.all_products_collection_url }}" class="footer-col__link">Ver todo</a>
{%- endif -%}
